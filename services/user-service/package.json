{
  "name": "user-service",
  "version": "1.0.0",
  "description": "User Authentication & Management Service",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node src/utils/seed.ts"
  },
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "@prisma/client": "^5.12.0",
    "prisma": "^5.12.0",
    "winston": "^3.13.0",
    "joi": "^17.12.0",
    "redis": "^4.6.0",
    "ioredis": "^5.3.0",
    "nodemailer": "^6.9.0",
    "uuid": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.8",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.0"
